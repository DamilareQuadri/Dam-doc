# Copy this file to `.env` and fill in the values.

# Port the server listens on. Render sets this automatically in production.
PORT=5000

# Secret used to sign JWTs — use a long, random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-long-random-secret-here

# MongoDB connection string.
#  - Local dev: leave empty to use an in-memory database (no setup required).
#  - Production (Render): set your MongoDB Atlas connection string, e.g.
#    mongodb+srv://<user>:<password>@<cluster>.mongodb.net/damdoc?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/damdoc?retryWrites=true&w=majority
