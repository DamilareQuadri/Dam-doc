# Copy this file to `.env` (or `.env.local`) and adjust as needed.
# Vite only exposes variables prefixed with VITE_ to the client.

# Base URL of the Dam-doc backend API (include the /api suffix).
# Production (Render):
VITE_API_BASE_URL=https://dam-doc.onrender.com/api

# Local development against a backend running on your machine:
# VITE_API_BASE_URL=http://localhost:5000/api
